ery-language\\/scripting\\/arguments"},{"title":"Built-in functions","path":"\\/reference\\/query-language\\/scripting\\/built-in-functions"},{"title":"Function context","path":"\\/reference\\/query-language\\/scripting\\/function-context"},{"title":"SurrealQL functions","path":"\\/reference\\/query-language\\/scripting\\/surrealql-functions"},{"title":"Type conversion","path":"\\/reference\\/query-language\\/scripting\\/type-conversion"}]}],"contentPath":"reference\\/query-language\\/statements\\/define\\/analyzer.mdx","breadcrumbs":["Statements","DEFINE"],"title":"DEFINE ANALYZER","description":"In the context of a database, an analyzer plays a crucial role in text processing and searching. It is defined by its name, a set of tokenizers, and a collection of filters."}}
