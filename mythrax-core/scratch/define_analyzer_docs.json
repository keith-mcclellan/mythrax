{"sdkVersions":{"surrealdb":"v3.2.0",".net":"0.10.2","php":"2.0.0-alpha.1","javascript":"2.0.4","python":"2.0.0","rust":"unknown","golang":"v1.5.0","java":"1.0.0-beta.1"},"pageId":"\\/src\\/pages\\/reference\\/query-language","routeParams":{},"data":{"ast":{"type":"root","children":[{"type":"blockquote","children":[{"type":"paragraph","children":[{"type":"text","value":"Before SurrealDB version 3.0.0-beta, the "},{"type":"inlineCode","value":"FULLTEXT ANALYZER"},{"type":"text","value":" clause used the syntax "},{"type":"inlineCode","value":"SEARCH ANALYZER"},{"type":"text","value":"."}]}],"noteKind":"note"},{"type":"paragraph","children":[{"type":"text","value":"In the context of a database, an analyzer plays a crucial role in text processing and searching. It is defined by its name, a set of tokenizers, and a collection of filters."}]},{"type":"paragraph","children":[{"type":"text","value":"The output of an analyzer can be experimented with by using the "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/functions\\/database-functions\\/search#searchanalyze","title":"!undefined","children":[{"type":"inlineCode","value":"search::analyze()"}]},{"type":"text","value":" function."}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"Requirements"}],"id":"requirements"},{"type":"list","variant":"unordered","start":"!undefined","children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"You must be authenticated as a root, namespace, or database user before you can use the "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" statement."}]}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/use","title":"!undefined","children":[{"type":"text","value":"You must select your namespace and database"}]},{"type":"text","value":" before you can use the "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" statement."}]}]}]},{"type":"heading","depth":2,"children":[{"type":"text","value":"Statement syntax"}],"id":"statement-syntax"},{"type":"jsxComponent","name":"Tabs","attributes":{"synckey":"define-analyzer-statement"},"children":[{"type":"jsxComponent","name":"TabItem","attributes":{"label":"SurrealQL Syntax"},"children":[{"type":"code","value":"DEFINE ANALYZER [ OVERWRITE | IF NOT EXISTS ] @name [ FUNCTION \n  @function ] [ TOKENIZERS @tokenizers ] [ FILTERS @filters ] [ \n  COMMENT @string ]","lang":"syntax","title":"SurrealQL Syntax"}],"position":{"start":1,"end":9}},{"type":"jsxComponent","name":"TabItem","attributes":{"label":"Railroad Diagram"},"children":[{"type":"jsxComponent","name":"RailroadDiagram","attributes":{"ast":"{\"type\":\"Diagram\",\"padding\":[10,20,10,20],\"children\":[{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"DEFINE\"},{\"type\":\"Terminal\",\"text\":\"ANALYZER\"},{\"type\":\"Optional\",\"child\":{\"type\":\"Choice\",\"index\":1,\"children\":[{\"type\":\"Terminal\",\"text\":\"OVERWRITE\"},{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"IF\"},{\"type\":\"Terminal\",\"text\":\"NOT\"},{\"type\":\"Terminal\",\"text\":\"EXISTS\"}]}]}},{\"type\":\"NonTerminal\",\"text\":\"@name\"},{\"type\":\"Optional\",\"child\":{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"FUNCTION\"},{\"type\":\"NonTerminal\",\"text\":\"@function\"}]}},{\"type\":\"Optional\",\"child\":{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"TOKENIZERS\"},{\"type\":\"NonTerminal\",\"text\":\"@tokenizers\"}]}},{\"type\":\"Optional\",\"child\":{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"FILTERS\"},{\"type\":\"NonTerminal\",\"text\":\"@filters\"}]}},{\"type\":\"Optional\",\"child\":{\"type\":\"Sequence\",\"children\":[{\"type\":\"Terminal\",\"text\":\"COMMENT\"},{\"type\":\"NonTerminal\",\"text\":\"@string\"}]}}]}]}"},"children":[],"position":{"start":3,"end":3}}],"position":{"start":10,"end":15}}],"position":{"start":17,"end":33}},{"type":"heading","depth":2,"children":[{"type":"text","value":"The "},{"type":"inlineCode","value":"FUNCTION"},{"type":"text","value":" clause"}],"id":"the-function-clause"},{"type":"paragraph","children":[{"type":"text","value":"The "},{"type":"inlineCode","value":"FUNCTION"},{"type":"text","value":" clause runs a preprocessing step on the initial input before tokenizers and filters run. The reference must be a "},{"type":"strong","children":[{"type":"text","value":"function path"}]},{"type":"text","value":" (not a call — omit parentheses), and the function must take and return a "},{"type":"inlineCode","value":"string"},{"type":"text","value":"."}]},{"type":"paragraph","children":[{"type":"text","value":"You can use either:"}]},{"type":"list","variant":"unordered","start":"!undefined","children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"a "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/define\\/function","title":"!undefined","children":[{"type":"inlineCode","value":"fn::"}]},{"type":"text","value":" user-defined function defined with "},{"type":"inlineCode","value":"DEFINE FUNCTION"},{"type":"text","value":", or"}]}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"a "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/define\\/module","title":"!undefined","children":[{"type":"inlineCode","value":"mod::"}]},{"type":"text","value":" function from a Surrealism "},{"type":"link","url":"\\/docs\\/learn\\/extensions\\/plugins\\/overview","title":"!undefined","children":[{"type":"text","value":"extension module"}]},{"type":"text","value":" defined with "},{"type":"inlineCode","value":"DEFINE MODULE"},{"type":"text","value":" (requires the "},{"type":"link","url":"\\/docs\\/reference\\/cli\\/surrealdb-cli\\/commands\\/start#experimental-capabilities","title":"!undefined","children":[{"type":"inlineCode","value":"surrealism"},{"type":"text","value":" experimental capability"}]},{"type":"text","value":")."}]}]}]},{"type":"code","value":"\\/**[test]\n\n[[test.results]]\nvalue = \"NONE\"\n\n[[test.results]]\nvalue = \"NONE\"\n\n[[test.results]]\nvalue = \"['BDlaerruS', 'ekil', 'I']\"\n\n*\\/\n\nDEFINE FUNCTION fn::backwardsify($input: string) -> string {\n    $input.split('').fold('', |$a, $b| $b + $a);\n};\n\nDEFINE ANALYZER backwards FUNCTION fn::backwardsify TOKENIZERS blank;\n\nsearch::analyze(\"backwards\", \"I like SurrealDB\");","lang":"surql"},{"type":"paragraph","children":[{"type":"text","value":"A Surrealism module function works the same way once the module is registered:"}]},{"type":"code","value":"DEFINE ANALYZER custom FUNCTION mod::demo::alter_string TOKENIZERS class;","lang":"surql"},{"type":"code","value":"[\n\t'BDlaerruS',\n\t'ekil',\n\t'I'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Tokenizers"}],"id":"tokenizers"},{"type":"paragraph","children":[{"type":"text","value":"Tokenizers are responsible for breaking down a given text into individual tokens based on a set of instructions. There are a couple of tokenizers that can be used while defining an analyzer as seen below:"}]},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"blank"}],"id":"blank"},{"type":"paragraph","children":[{"type":"text","value":"The blank tokenizer breaks down a text into tokens by creating a new token each time it encounters a space, tab, or newline character. It's a straightforward way to split text into words or chunks based on whitespace."}]},{"type":"code","value":"DEFINE ANALYZER example_blank TOKENIZERS blank;\nsearch::analyze(\"example_blank\", \"hello world\");","lang":"surql"},{"type":"code","value":"[\n\t'hello',\n\t'world'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"camel"}],"id":"camel"},{"type":"paragraph","children":[{"type":"text","value":"The camel tokenizer is used for identifying and creating tokens when the next character in the text is uppercase. This is particularly useful for processing camelCase or PascalCase text, common in programming, to split them into meaningful words."}]},{"type":"code","value":"DEFINE ANALYZER example_camel TOKENIZERS camel;\nsearch::analyze(\"example_camel\", \"helloWorld\");","lang":"surql"},{"type":"code","value":"[\n\t'hello',\n\t'World'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"class"}],"id":"class"},{"type":"paragraph","children":[{"type":"text","value":"The class tokenizer segments text into tokens by detecting changes (digit, letter, punctuation, blank) in the Unicode class of characters. It creates a new token when the character class changes, distinguishing between digits, letters, punctuation, and blanks. This allows for flexible tokenization based on character types."}]},{"type":"code","value":"DEFINE ANALYZER example_class TOKENIZERS class;\nsearch::analyze(\"example_class\", \"123abc!XYZ\");","lang":"surql"},{"type":"code","value":"[\n\t'123',\n\t'abc',\n\t'!',\n\t'XYZ'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"punct"}],"id":"punct"},{"type":"paragraph","children":[{"type":"text","value":"The punct tokenizer generates tokens by breaking the text whenever a punctuation character is encountered. It's suitable for tokenizing sentences or breaking text into smaller units based on punctuation marks."}]},{"type":"code","value":"DEFINE ANALYZER example_punct TOKENIZERS punct;\nsearch::analyze(\"example_punct\", \"Hello, World!\");","lang":"surql"},{"type":"code","value":"[\n\t'Hello',\n\t',',\n\t'World',\n\t'!'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Filters"}],"id":"filters"},{"type":"paragraph","children":[{"type":"text","value":"Filters take on the task of transforming these tokens for further processing and analysis."}]},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"ascii"}],"id":"ascii"},{"type":"paragraph","children":[{"type":"text","value":"The ascii filter is responsible for processing tokens by replacing or removing diacritical marks (accents and special characters) from the text. It helps standardize text by converting accented characters to their basic ASCII equivalents, making it more suitable for various text analysis tasks."}]},{"type":"code","value":"DEFINE ANALYZER example_ascii TOKENIZERS class FILTERS ascii;\nsearch::analyze(\"example_ascii\", \"résumé café\");","lang":"surql"},{"type":"code","value":"[\n\t'resume',\n\t'cafe'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"lowercase"}],"id":"lowercase"},{"type":"paragraph","children":[{"type":"text","value":"The lowercase filter converts tokens to lowercase, ensuring that text is consistently in lowercase format. This is often used to make text case-insensitive for search and analysis purposes."}]},{"type":"code","value":"DEFINE ANALYZER example_lowercase TOKENIZERS class FILTERS lowercase;\nsearch::analyze(\"example_lowercase\", \"Hello World\");","lang":"surql"},{"type":"code","value":"[\n\t'hello',\n\t'world'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"uppercase"}],"id":"uppercase"},{"type":"paragraph","children":[{"type":"text","value":"The uppercase filter converts tokens to uppercase, ensuring text consistency in uppercase format. It can be useful when case-insensitivity is required for specific analysis or search operations."}]},{"type":"paragraph","children":[{"type":"text","value":"For example, if you had the text "},{"type":"strong","children":[{"type":"text","value":"\"Hello World\""}]},{"type":"text","value":", the uppercase filter would create two tokens, "},{"type":"strong","children":[{"type":"text","value":"["},{"type":"text","value":"\"HELLO\", \"WORLD\"]"}]},{"type":"text","value":". Below is an example of how to use the uppercase filter:"}]},{"type":"code","value":"DEFINE ANALYZER example_uppercase TOKENIZERS class FILTERS uppercase;\nsearch::analyze(\"example_uppercase\", \"Hello World\");","lang":"surql"},{"type":"code","value":"[\n\t'HELLO',\n\t'WORLD'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"edgengram(min,max)"}],"id":"edgengramminmax"},{"type":"paragraph","children":[{"type":"text","value":"The edgengram filter is used to create tokens that represent prefixes of terms. It generates a sequence of tokens that gradually build up a term, which can be useful for autocomplete or searching based on partial words. It accepts two parameters "},{"type":"inlineCode","value":"min"},{"type":"text","value":" and "},{"type":"inlineCode","value":"max"},{"type":"text","value":" which define the minimum and maximum amount of characters in the prefix."}]},{"type":"paragraph","children":[{"type":"text","value":"For example, if you had the text "},{"type":"strong","children":[{"type":"text","value":"\"apple banana\""}]},{"type":"text","value":", the edgengram filter would create six tokens, "},{"type":"strong","children":[{"type":"text","value":"["},{"type":"text","value":"\"a\", \"ap\", \"app\", \"b\", \"ba\", \"ban\"]"}]},{"type":"text","value":". Below is an example of how to use the edgengram filter:"}]},{"type":"code","value":"DEFINE ANALYZER example_edgengram TOKENIZERS class FILTERS\n  edgengram(1,3);\nsearch::analyze(\"example_edgengram\", \"apple banana\");","lang":"surql"},{"type":"code","value":"[\n\t'a',\n\t'ap',\n\t'app',\n\t'b',\n\t'ba',\n\t'ban'\n]"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"mapper(path)"}],"id":"mapperpath"},{"type":"paragraph","children":[{"type":"text","value":"The mapping filter is designed to enable lemmatization within SurrealDB."}]},{"type":"paragraph","children":[{"type":"text","value":"Lemmatization is the process of reducing words to their base or dictionary form. The mapper mechanism allows users to specify a custom dictionary file that maps terms to their base forms. This dictionary file is then used by SurrealDB’s analyzer to standardize terms as they are indexed, improving search consistency."}]},{"type":"paragraph","children":[{"type":"text","value":"This is particularly useful for handling irregular verbs and other terms that the default \"snowball\" filter cannot handle. Lemmatization files are easy to put together and to find online, making it possible to customize full-text search for smaller languages."}]},{"type":"heading","depth":4,"children":[{"type":"text","value":"Filesystem allowlist"}],"id":"filesystem-allowlist"},{"type":"paragraph","children":[{"type":"text","value":"A "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" statement with "},{"type":"inlineCode","value":"mapper('\u003cpath>')"},{"type":"text","value":" opens the dictionary file on the "},{"type":"strong","children":[{"type":"text","value":"host filesystem"}]},{"type":"text","value":" when the analyzer is defined. Access is gated by "},{"type":"link","url":"\\/docs\\/reference\\/cli\\/surrealdb-cli\\/environment-variables#file-config","title":"!undefined","children":[{"type":"inlineCode","value":"SURREAL_FILE_ALLOWLIST"}]},{"type":"text","value":", without which no paths are permitted. Set one or more directories before using "},{"type":"inlineCode","value":"mapper()"},{"type":"text","value":":"}]},{"type":"code","value":"# Unix — colon-separated directories\nSURREAL_FILE_ALLOWLIST=\"\\/var\\/surreal\\/dicts:\\/opt\\/wordlists\" surreal start --user root --pass secret","lang":"bash"},{"type":"code","value":"# Windows — semicolon-separated directories\n$env:SURREAL_FILE_ALLOWLIST = \"C:\\dicts;D:\\wordlists\"\nsurreal start --user root --pass secret memory","lang":"powershell"},{"type":"paragraph","children":[{"type":"text","value":"The path in "},{"type":"inlineCode","value":"mapper()"},{"type":"text","value":" must resolve to a file "},{"type":"strong","children":[{"type":"text","value":"under"}]},{"type":"text","value":" an allowed directory. Paths outside the allowlist are rejected at "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" time."}]},{"type":"blockquote","children":[{"type":"paragraph","children":[{"type":"text","value":"This allowlist is for analyzer dictionary files only. The experimental "},{"type":"link","url":"\\/docs\\/learn\\/schema-management\\/files\\/buckets","title":"!undefined","children":[{"type":"text","value":"files"}]},{"type":"text","value":" feature uses "},{"type":"link","url":"\\/docs\\/reference\\/cli\\/surrealdb-cli\\/environment-variables#file-config","title":"!undefined","children":[{"type":"inlineCode","value":"SURREAL_BUCKET_FOLDER_ALLOWLIST"}]},{"type":"text","value":" instead."}]}],"noteKind":"note"},{"type":"paragraph","children":[{"type":"text","value":"How does the mapper work?"}]},{"type":"paragraph","children":[{"type":"text","value":"Configuration: In the SQL statement below, the mapper parameter is specified within the analyzer definition.\nThis parameter points to the file that contains the term mappings for lemmatization."}]},{"type":"code","value":"DEFINE ANALYZER lemme_english TOKENIZERS blank,class FILTERS\n  lowercase,mapper( '..\\/tests\\/data\\/lemmatization-en.txt' );\n\nRETURN [\n    search::analyze(\"lemme_english\", \"He drove and swam\"),\n];","lang":"surql"},{"type":"code","value":"[\n\t[\n\t\t'he',\n\t\t'drive',\n\t\t'and',\n\t\t'swim'\n\t]\n]","lang":"surql","title":"Output"},{"type":"paragraph","children":[{"type":"text","value":"Dictionary File Structure: The file specified in the mapper parameter must follow this format:"}]},{"type":"list","variant":"unordered","start":"!undefined","children":[{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"Each line contains a pair of terms separated by a tab."}]}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"The first term represents the canonical (base form) of the word."}]}]},{"type":"listItem","children":[{"type":"paragraph","children":[{"type":"text","value":"The second term is the form to be mapped to this base form."}]}]}]},{"type":"paragraph","children":[{"type":"text","value":"Example file format:"}]},{"type":"code","value":"drive\tdriven\ndrive\tdrives\ndrive\tdriving\ndrive\tdrove\nswim\tswam\nswim\tswimming\nswim\tswims\nswim\tswum"},{"type":"paragraph","children":[{"type":"text","value":"Usage: When this analyzer is applied to a text, any word that matches the mapped term in the dictionary file will be replaced by its base form before indexing. This helps ensure consistency in search results by consolidating different forms of a word to a single, standardized entry."}]},{"type":"paragraph","children":[{"type":"text","value":"By using this custom dictionary-based mapper, you can control how irregular forms and other variations of terms are indexed,\nmaking search behavior more predictable and comprehensive."}]},{"type":"paragraph","children":[{"type":"text","value":"The following example shows how lemmatization can be used to generate a list of words and their respective frequencies. Other notable functionalities in the example are the "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/functions\\/database-functions\\/string#stringis_alpha","title":"!undefined","children":[{"type":"inlineCode","value":"string::is_alpha()"}]},{"type":"text","value":" function inside "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/functions\\/database-functions\\/array#arrayfilter","title":"!undefined","children":[{"type":"inlineCode","value":"array::filter()"}]},{"type":"text","value":" to remove all non-alphabetic strings, the "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/functions\\/database-functions\\/type#typerecord","title":"!undefined","children":[{"type":"inlineCode","value":"type::record()"}]},{"type":"text","value":" function to construct a record ID from two strings, and an "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/upsert","title":"!undefined","children":[{"type":"inlineCode","value":"UPSERT"}]},{"type":"text","value":" statement to create a record if one does not exist, or update it otherwise."}]},{"type":"code","value":"DEFINE ANALYZER lemme_english TOKENIZERS blank,class FILTERS\n  lowercase,mapper( '..\\/tests\\/data\\/lemmatization-en.txt' );\n\nLET $text = \"The Wheel of Time turns,\n  and Ages come and pass,\n  leaving memories that become legend. Legend fades to myth,\n  and even myth is long forgotten when the Age that gave it birth comes again. In one Age,\n  called the Third Age by some,\n  an Age yet to come,\n  an Age long past,\n  a wind rose in the Mountains of Mist. The wind was not the beginning. There are neither beginnings nor endings to the turning of the Wheel of Time. But it was a beginning.\";\n\nLET $words = search::analyze(\"lemme_english\", $text)\n    .filter(|$c| $c.is_alpha());\nFOR $word IN $words {\n    UPSERT type::record(\"word\", $word) SET frequency += 1;\n};\n\nSELECT * FROM word WHERE frequency >=3 ORDER BY frequency DESC;","lang":"surql"},{"type":"code","value":"[\n\t{\n\t\tfrequency: 8,\n\t\tid: word:the\n\t},\n\t{\n\t\tfrequency: 6,\n\t\tid: word:age\n\t},\n\t{\n\t\tfrequency: 4,\n\t\tid: word:a\n\t},\n\t{\n\t\tfrequency: 4,\n\t\tid: word:be\n\t},\n\t{\n\t\tfrequency: 4,\n\t\tid: word:of\n\t},\n\t{\n\t\tfrequency: 3,\n\t\tid: word:and\n\t},\n\t{\n\t\tfrequency: 3,\n\t\tid: word:come\n\t},\n\t{\n\t\tfrequency: 3,\n\t\tid: word:to\n\t}\n]","lang":"surql","title":"Output"},{"type":"paragraph","children":[{"type":"text","value":"A mapper can also be used for ad-hoc filtering, as long as the file referenced contains two single words separated by a tab. Take the following file for example:"}]},{"type":"code","value":"NOT_FOUND\tFile_not_found\nNOT_FOUND\tDatei_nicht_gefunden\nNOT_FOUND\tFichier_non_trouvé\nTIMEOUT\tTimed_out\nTIMEOUT\tDélai_expiré\nTIMEOUT\tZeitüberschreitung","lang":"title"},{"type":"paragraph","children":[{"type":"text","value":"An analyzer that uses a single mapper filter can then use this lemmatizer to unify multilingual error messages into a single output."}]},{"type":"code","value":"DEFINE ANALYZER error_filter FILTERS mapper('error_filter.txt');\n\nLET $messages = \n\t[\"File not found\", \"Datei nicht gefunden\", \"Zeitüberschreitung\"]\n\t.map(|$word| $word.replace(' ', '_'))\n\t.join(' ');\nsearch::analyze(\"error_filter\", $messages);","lang":"surql"},{"type":"code","value":"[\n\t'NOT_FOUND',\n\t'NOT_FOUND',\n\t'TIMEOUT'\n]","lang":"surql","title":"Output"},{"type":"paragraph","children":[{"type":"text","value":"Example using the same mapper to search for errors in multiple languages:"}]},{"type":"code","value":"DEFINE ANALYZER error_filter FILTERS mapper('error_filter.txt');\nDEFINE INDEX OVERWRITE errors\n  ON TABLE error FIELDS message FULLTEXT ANALYZER error_filter;\n\nFOR $message IN [\"File not found\",\n  \"Datei nicht gefunden\",\n  \"Zeitüberschreitung\"] {\n\tCREATE error SET message = $message.replace(' ',\n\t  '_'),\n\t  at = time::now();\n};\n\nSELECT * FROM error WHERE message @@ \"NOT_FOUND\";","lang":"surql"},{"type":"code","value":"[\n\t{\n\t\tat: d'2024-11-13T03:56:12.039252Z',\n\t\tid: error:acbc044syhnx54wzs3n9,\n\t\tmessage: 'File_not_found'\n\t},\n\t{\n\t\tat: d'2024-11-13T03:56:12.043643Z',\n\t\tid: error:5ifxic9s750x24ts4zof,\n\t\tmessage: 'Datei_nicht_gefunden'\n\t}\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"ngram(min,max)"}],"id":"ngramminmax"},{"type":"paragraph","children":[{"type":"text","value":"The ngram filter is used to create a sequence of 'n' tokens from a given sample of text or speech. These items can be syllables, letters, words or base pairs according to the application. It accepts two parameters "},{"type":"inlineCode","value":"min"},{"type":"text","value":" and "},{"type":"inlineCode","value":"max"},{"type":"text","value":" which indicates that you want to create n-grams starting from min to size of max."}]},{"type":"code","value":"DEFINE ANALYZER example_ngram TOKENIZERS class FILTERS ngram(1,3);\nsearch::analyze(\"example_ngram\", \"apple banana\");","lang":"surql"},{"type":"code","value":"[\n\t'a',\n\t'ap',\n\t'app',\n\t'p',\n\t'pp',\n\t'ppl',\n\t'p',\n\t'pl',\n\t'ple',\n\t'l',\n\t'le',\n\t'e',\n\t'b',\n\t'ba',\n\t'ban',\n\t'a',\n\t'an',\n\t'ana',\n\t'n',\n\t'na',\n\t'nan',\n\t'a',\n\t'an',\n\t'ana',\n\t'n',\n\t'na',\n\t'a'\n]","lang":"surql","title":"Output"},{"type":"heading","depth":3,"children":[{"type":"inlineCode","value":"snowball(language)"}],"id":"snowballlanguage"},{"type":"paragraph","children":[{"type":"text","value":"The snowball filter applies Snowball stemming to tokens, reducing them to their root form and converts the case to lowercase. The following supported languages can be passed as a parameter in snowball: Arabic, Danish, Dutch, English, French, German, Greek, Hungarian, Italian, Norwegian, Portuguese, Romanian, Russian, Spanish, Swedish, Tamil, Turkish."}]},{"type":"code","value":"DEFINE ANALYZER english_snowball TOKENIZERS class FILTERS\n  snowball(english);\nDEFINE ANALYZER german_snowball TOKENIZERS class FILTERS\n  snowball(german);\n\nRETURN [\n    search::analyze(\"english_snowball\",\n      \"Looking at some running cats\")\n    search::analyze(\"german_snowball\",\n      \"Sollen wir was trinken gehen?\")\n];","lang":"surql"},{"type":"code","value":"[\n\t[\n\t\t'look',\n\t\t'at',\n\t\t'some',\n\t\t'run',\n\t\t'cat'\n\t],\n\t[\n\t\t'soll',\n\t\t'wir',\n\t\t'was',\n\t\t'trink',\n\t\t'geh',\n\t\t'?'\n\t]\n]","lang":"surql","title":"Output"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Using "},{"type":"inlineCode","value":"IF NOT EXISTS"},{"type":"text","value":" clause"}],"id":"using-if-not-exists-clause"},{"type":"paragraph","children":[{"type":"text","value":"The "},{"type":"inlineCode","value":"IF NOT EXISTS"},{"type":"text","value":" clause can be used to define an analyzer only if it does not already exist. You should use the "},{"type":"inlineCode","value":"IF NOT EXISTS"},{"type":"text","value":" clause when defining an analyzer in SurrealDB if you want to ensure that the analyzer is only created if it does not already exist. If the analyzer already exists, the "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" statement will return an error."}]},{"type":"paragraph","children":[{"type":"text","value":"It's particularly useful when you want to safely attempt to define a analyzer without manually checking its existence first."}]},{"type":"paragraph","children":[{"type":"text","value":"On the other hand, you should not use the "},{"type":"inlineCode","value":"IF NOT EXISTS"},{"type":"text","value":" clause when you want to ensure that the analyzer definition is updated regardless of whether it already exists. In such cases, you might prefer using the "},{"type":"inlineCode","value":"OVERWRITE"},{"type":"text","value":" clause, which allows you to define a analyzer and overwrite an existing one if it already exists, ensuring that the latest version of the analyzer definition is always in use."}]},{"type":"code","value":"-- Create an ANALYZER if it does not already exist\nDEFINE ANALYZER IF NOT EXISTS example TOKENIZERS blank;","lang":"surql"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Using "},{"type":"inlineCode","value":"OVERWRITE"},{"type":"text","value":" clause"}],"id":"using-overwrite-clause"},{"type":"jsxComponent","name":"Since","attributes":{"v":"v2.0.0"},"children":[],"position":{"start":528,"end":528}},{"type":"paragraph","children":[{"type":"text","value":"The "},{"type":"inlineCode","value":"OVERWRITE"},{"type":"text","value":" clause can be used to create an analyzer and overwrite an existing one if it already exists. You should use the "},{"type":"inlineCode","value":"OVERWRITE"},{"type":"text","value":" clause when you want to modify an existing analyzer definition. If the analyzer already exists, the "},{"type":"inlineCode","value":"DEFINE ANALYZER"},{"type":"text","value":" statement will overwrite the existing analyzer definition with the new one."}]},{"type":"code","value":"-- Create an ANALYZER and overwrite if it already exists\nDEFINE ANALYZER OVERWRITE example TOKENIZERS blank;","lang":"surql"},{"type":"heading","depth":2,"children":[{"type":"text","value":"More examples"}],"id":"more-examples"},{"type":"paragraph","children":[{"type":"text","value":"Examples on application of analyzers to indexes can be found in the documenation on "},{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/define\\/indexes","title":"!undefined","children":[{"type":"inlineCode","value":"DEFINE INDEX"}]},{"type":"text","value":" statement"}]},{"type":"paragraph","children":[{"type":"text","value":"This example creates an analyzer that tokenizes text based on the class of characters and then applies the lowercase filter to the tokens."}]},{"type":"code","value":"-- Creates a simple analyzer removing diacritics marks\nDEFINE ANALYZER ascii TOKENIZERS class FILTERS lowercase,ascii;","lang":"surql"},{"type":"paragraph","children":[{"type":"text","value":"This example creates an analyzer specifically designed for processing English texts."}]},{"type":"code","value":"-- Creates an analyzer suitable for English text\nDEFINE ANALYZER english TOKENIZERS class FILTERS snowball(english);","lang":"surql"},{"type":"paragraph","children":[{"type":"text","value":"This example creates an analyzer specifically designed for auto-completion tasks."}]},{"type":"code","value":"-- Creates an analyzer suitable for auto-completion.\nDEFINE ANALYZER autocomplete FILTERS lowercase,edgengram(2,10);","lang":"surql"},{"type":"paragraph","children":[{"type":"text","value":"This example creates an analyzer specifically designed for source code analysis."}]},{"type":"code","value":"-- Creates an analyzer suitable for source code analysis.\nDEFINE ANALYZER code TOKENIZERS class,camel FILTERS lowercase,ascii;","lang":"surql"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Removing analyzers"}],"id":"removing-analyzers"},{"type":"paragraph","children":[{"type":"link","url":"\\/docs\\/reference\\/query-language\\/statements\\/remove","title":"!undefined","children":[{"type":"inlineCode","value":"REMOVE ANALYZER"}]},{"type":"text","value":" fails while any full-text index still references the analyzer. Remove or redefine those indexes first, then remove the analyzer. "},{"type":"inlineCode","value":"REMOVE ANALYZER IF EXISTS"},{"type":"text","value":" does not bypass this check when the analyzer is still in use."}]}]},"headings":[{"id":"requirements","text":"Requirements","depth":2},{"id":"statement-syntax","text":"Statement syntax","depth":2},{"id":"the-function-clause","text":"The FUNCTION clause","depth":2},{"id":"tokenizers","text":"Tokenizers","depth":2},{"id":"blank","text":"blank","depth":3},{"id":"camel","text":"camel","depth":3},{"id":"class","text":"class","depth":3},{"id":"punct","text":"punct","depth":3},{"id":"filters","text":"Filters","depth":2},{"id":"ascii","text":"ascii","depth":3},{"id":"lowercase","text":"lowercase","depth":3},{"id":"uppercase","text":"uppercase","depth":3},{"id":"edgengramminmax","text":"edgengram(min,max)","depth":3},{"id":"mapperpath","text":"mapper(path)","depth":3},{"id":"ngramminmax","text":"ngram(min,max)","depth":3},{"id":"snowballlanguage","text":"snowball(language)","depth":3},{"id":"using-if-not-exists-clause","text":"Using IF NOT EXISTS clause","depth":2},{"id":"using-overwrite-clause","text":"Using OVERWRITE clause","depth":2},{"id":"more-examples","text":"More examples","depth":2},{"id":"removing-analyzers","text":"Removing analyzers","depth":2}],"navigation":[{"title":"Overview","icon":"!undefined","links":[{"title":"SurrealQL","path":"\\/reference\\/query-language"}]},{"title":"Language Primitives","icon":"!undefined","links":[{"title":"Statements","path":"\\/reference\\/query-language\\/language-primitives\\/statements"},{"title":"Operators","path":"\\/reference\\/query-language\\/language-primitives\\/operators"},{"title":"Parameters","path":"\\/reference\\/query-language\\/language-primitives\\/parameters"},{"title":"Transactions","path":"\\/reference\\/query-language\\/language-primitives\\/transactions"},{"title":"Comments","path":"\\/reference\\/query-language\\/language-primitives\\/comments"},{"title":"Record links","path":"\\/reference\\/query-language\\/language-primitives\\/record-links"},{"title":"Record references","path":"\\/reference\\/query-language\\/language-primitives\\/record-references"},{"title":"Casting","path":"\\/reference\\/query-language\\/language-primitives\\/casting"},{"title":"Formatters","path":"\\/reference\\/query-language\\/language-primitives\\/formatters"},{"title":"Idioms","path":"\\/reference\\/query-language\\/language-primitives\\/idioms"},{"title":"Data types","path":"\\/reference\\/query-language\\/language-primitives\\/data-types","children":[{"title":"Arrays","path":"\\/reference\\/query-language\\/language-primitives\\/data-types\\/arrays"},{"title":"Booleans","path":"\\/reference\\/query-language\\/language-primitives\\/data-types\\/booleans"},{"title":"Bytes","path":"\\/reference\\/query-language\\/language-primitives\\/data-types\\/bytes"},{"title":"Closures","path":"\\/reference\\/query-language\\/language-primitives\\/data-types\\/closures"},{"title":"Datetimes","path":"\\/reference\\/query-language\\/language-primitives\\/data-types\\/datetimes"},{"title":"Durations","path":"\\/reference\\/query-language\\/language-primit